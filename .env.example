# Copy this file to .env and fill in real values for local development.
# In production (Render, etc.), set these in your host's dashboard instead — do NOT ship a real .env file.

# Required in production. Pick a long random string, e.g. via `openssl rand -base64 32`.
# Leave unset locally to use the dev fallback (the app still works, but operator endpoints use a known default).
APP_PASSWORD=

# Optional. Enables AI root-cause analysis in the Stability Sentinel. Without it, a heuristic engine is used.
GEMINI_API_KEY=

# Optional. External Postgres connection string for persisting simulation runs and research logs.
# Works with Neon, Supabase, Render Postgres, AWS RDS, and any other Postgres provider.
# Example (Neon):    postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require
# Example (Supabase): postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres
# Leave blank to run without persistence — the app still works, just won't save runs.
DATABASE_URL=

# Dev only. Disables TLS certificate validation for the Postgres connection above.
# Forbidden in production (the server will refuse to boot). Set to "true" only for
# local DBs with self-signed certs.
PG_SSL_INSECURE=
